# Copy to .env and adjust. Do not commit .env.

# PostgreSQL
POSTGRES_USER=observability
POSTGRES_PASSWORD=observability_dev
POSTGRES_DB=identity_observability
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6379

# Connection strings for your app (use same names in backend)
DATABASE_URL=postgres://observability:observability_dev@localhost:5433/identity_observability?sslmode=disable
REDIS_URL=redis://localhost:6379/0
